[Unit]
Description=Market data collector — EOD run (FRED + vix_utils)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=YOUR_USER
WorkingDirectory=/path/to/derivative-implied-pricing
ExecStart=/path/to/venv/bin/python -m src.collector --mode=eod
StandardOutput=journal
StandardError=journal
TimeoutStartSec=120
